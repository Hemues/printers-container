#!/bin/bash
# /etc/scripts/podman-printers-updater-inside-pod
# Run as root. Updates the printers container under the 'printers' user's
# rootless podman (preserving /configs volume with users, printers, Samba DB).
set -euo pipefail

IMAGE="ghcr.io/hemues/printers:latest"
CONTAINER="printers"
DATA_BASE="/storage/pods-data/printers"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Updating ${CONTAINER}..."

# Ensure data dirs exist and are owned by the printers user
install -d -m 755 -o printers -g printers \
    "${DATA_BASE}/printings" \
    "${DATA_BASE}/configs" \
    "${DATA_BASE}/logs"

# All podman operations must run as the printers user (rootless podman).
# This preserves the existing container storage, configs, and user data.
sudo -u printers -i bash -c "
    podman stop  ${CONTAINER} 2>/dev/null || true
    podman rm    ${CONTAINER} 2>/dev/null || true
    podman rmi   ${IMAGE}     2>/dev/null || true
    podman pull  ${IMAGE}
    podman run -d \
        --name ${CONTAINER} \
        --restart unless-stopped \
        -p 8082:8082 \
        -p 139:139 -p 445:445 \
        -p 137:137/udp -p 138:138/udp \
        -v ${DATA_BASE}/printings:/printings \
        -v ${DATA_BASE}/configs:/configs \
        -v ${DATA_BASE}/logs:/logs \
        ${IMAGE}
"

echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ${CONTAINER} updated and started."
